# Server
PORT=5050
NODE_ENV=development
LOG_LEVEL=info
ENABLE_HSTS=false
SWAGGER_URL=http://localhost:5050

# API Security
API_KEY=change-me-in-production

# Limits
MAX_BODY_SIZE_MB=5
REQUEST_TIMEOUT_MS=15000

# Temporary files (use ./temp for permissions en Docker)
TEMP_DIR=./temp

# Archive Tool (bsdtar, rar, or 7z)
RAR_BIN=bsdtar

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
