# Production environment configuration
# Copy to .env.production and fill in your values

# REQUIRED: Change this to a strong, random key
API_KEY=your-production-api-key-here-change-this

# Server
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Limits
MAX_BODY_SIZE_MB=5
REQUEST_TIMEOUT_MS=15000

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Temporary files
TEMP_DIR=/tmp/rarbox

# RAR binary (use ugrep or rar if available)
RAR_BIN=rar
