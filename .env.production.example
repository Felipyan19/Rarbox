# Production environment configuration
# Copy to .env.production and fill in your values

# REQUIRED: Change this to a strong, random key
API_KEY=your-production-api-key-here-change-this

# Server
NODE_ENV=production
PORT=5050
LOG_LEVEL=info
ENABLE_HSTS=false
SWAGGER_URL=http://149.130.164.187:5050

# Limits
MAX_BODY_SIZE_MB=5
REQUEST_TIMEOUT_MS=15000

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Temporary files (use ./temp para permisos en Docker)
TEMP_DIR=./temp

# RAR binary (use ugrep or rar if available)
RAR_BIN=rar
